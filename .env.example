# ============================================
# CONTENT LAB — API KEYS
# Run: cp .env.example .env  then fill in your keys
# ============================================

# --- AI Script Generation ---
# Ollama = local & FREE (recommended)
OLLAMA_MODEL=mistral
OLLAMA_URL=http://localhost:11434
# Optional paid fallbacks
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Text-to-Speech ---
# Coqui TTS = local & FREE
TTS_ENGINE=coqui
# ElevenLabs = paid, ultra-realistic
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id

# --- Stock Footage (Pexels is FREE) ---
PEXELS_API_KEY=your_pexels_key_here
PIXABAY_API_KEY=your_pixabay_key_here

# --- YouTube Upload ---
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_CHANNEL_ID=your_channel_id

# --- TikTok Upload ---
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token

# --- Facebook / Meta Upload ---
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_ACCESS_TOKEN=your_page_access_token

# --- Output Settings ---
OUTPUT_DIR=./output
VIDEO_RESOLUTION=1920x1080
SHORTS_RESOLUTION=1080x1920
